{
  "manifest_version": 3,
  "name": "Research Board (Local)",
  "version": "1.11.2",
  "browser_specific_settings": {
    "gecko": {
      "id": "your-addon-id@example.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "description": "Lokales Recherche-Board in der Sidebar: Themen, Links, Textauszuege und optionale Notizen inkl. Import/Export.",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "contextMenus",
    "alarms"
  ],
  "background": {
    "scripts": [
      "shared/compat.js",
      "shared/db.js",
      "shared/url-transform.js",
      "shared/auto-backup.js",
      "background.js"
    ]
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "sidebar_action": {
    "default_title": "Research Board",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },
  "action": {
    "default_title": "Research Board",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  }
}
